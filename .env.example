# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/quintou

# JWT Config
SECRET_KEY=sua_chave_secreta_super_segura_aqui_para_desenvolvimento
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AWS S3 (Upload de imagens)
AWS_ACCESS_KEY_ID=sua_aws_key
AWS_SECRET_ACCESS_KEY=sua_aws_secret
AWS_REGION=us-east-1
S3_BUCKET_NAME=quintou-images-dev

# Stripe (Pagamentos)
STRIPE_SECRET_KEY=sk_test_sua_chave_stripe
STRIPE_WEBHOOK_SECRET=whsec_seu_webhook_secret

# Email Configuration
# Escolha um provedor de email:

# Opção 1: SendGrid (Recomendado para produção)
SENDGRID_API_KEY=SG.sua_api_key_sendgrid
EMAIL_FROM=noreply@quintou.com

# Opção 2: SMTP (Gmail, Outlook, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu_email@gmail.com
# SMTP_PASSWORD=sua_senha_de_app
# SMTP_TLS=true
# EMAIL_FROM=seu_email@gmail.com

# Frontend URL (para links de reset de senha)
FRONTEND_URL=https://app.quintou.com

# Firebase (Notificações Push)
FIREBASE_CREDENTIALS_PATH=firebase-credentials.json
# Ou use JSON direto:
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# CPF Hub (Validação de CPF)
CPFHUB_API_KEY=sua_chave_cpfhub

# Mapbox (Geocoding de endereços)
MAPBOX_ACCESS_TOKEN=pk.sua_chave_mapbox

# Didit (Verificação de identidade/KYC)
DIDIT_API_KEY=sua_chave_didit
DIDIT_WEBHOOK_SECRET=seu_webhook_secret_didit
DIDIT_WORKFLOW_ID=seu_workflow_id

# Redis (Cache e Rate Limiting)
REDIS_URL=redis://localhost:6379/0

# Configurações de API
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
